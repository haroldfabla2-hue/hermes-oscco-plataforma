generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("EDITOR") // ADMIN, EDITOR, PRESS
  name      String
  notes     TicketNote[]
}

model Post {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String   // Markdown
  excerpt     String?
  featuredImg String?
  category    String?  // EducaciÃ³n, Salud, Infraestructura, Seguridad
  published   Boolean  @default(false)
  publishedAt DateTime?
  authorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Work {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  location      String
  status        String   // PLANNED, IN_PROGRESS, COMPLETED
  progress      Int      @default(0)
  beforeImg     String?
  afterImg      String?
  videoUrl      String?
  description   String
  storytelling  String?  // El relato de la obra
  results       String?  // Impacto medible
  gallery       String?  // JSON stringified array of images
  featured      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model VideoBlog {
  id          String   @id @default(uuid())
  title       String
  youtubeId   String
  description String?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
}

model Citizen {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  email     String?
  district  String?
  tickets   Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ticket {
  id                 String       @id @default(uuid())
  citizenId          String
  citizen            Citizen      @relation(fields: [citizenId], references: [id])
  topic              String       // Seguridad, Limpieza, etc.
  subject            String
  initialDescription String
  status             String       @default("NEW") // NEW, OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority           String       @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  notes              TicketNote[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model TicketNote {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())
}

model Lead {
  id          String   @id @default(uuid())
  name        String
  phone       String
  district    String
  message     String?
  createdAt   DateTime @default(now())
}

model Proposal {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String
  icon        String?
  imageUrl    String?
  category    String
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
